{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "vite/client",
      "node"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "wailsjs/*": [
        "wailsjs/*"
      ]
    },
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "wailsjs/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "wails.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "node_modules/gray-matter/gray-matter.d.ts",
    "src/components/MonacoMarkdownEditor/theme.js"
  ]
}